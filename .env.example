# Copy to .env and fill with strong secrets before deploy
USE_PGLITE=true
DATABASE_URL="postgresql://postgres:password@localhost:5432/lingoarc"
NEXTAUTH_URL="http://localhost:3000"
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET="replace-with-long-random-secret-min-32-chars"
# Optional: DeepL API key for even better EN↔RU (free tier ends with :fx)
# DEEPL_API_KEY="your-deepl-key:fx"
